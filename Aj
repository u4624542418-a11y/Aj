local function fetchJobId()
    local res=nil
    local ok1=pcall(function()
        res=request({Url=API_URL,Method="GET"})
    end)
    if not ok1 or not res then
        local ok2=pcall(function()
            res=syn.request({Url=API_URL,Method="GET"})
        end)
        if not ok2 or not res then
            -- Fallback HttpService
            local ok3,body=pcall(function()
                return HttpService:GetAsync(API_URL,true)
            end)
            if ok3 and body then
                res={Body=body}
            else
                return nil,"HTTP error"
            end
        end
    end
    if not res or not res.Body or res.Body=="" then return nil,"Réponse vide" end
    local ok,data=pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not ok or not data then return nil,"JSON invalide" end
    if data.jobId and data.jobId~="" then return data.jobId,nil end
    return nil,"Pas de jobId"
end

local function joinJobId(jobId)
    if not jobId or jobId=="" then return false end
    local ok=pcall(function()
        TeleportService:TeleportToPlaceInstance(PLACE_ID,jobId,player)
    end)
    if ok then return true end
    local ok2=pcall(function()
        local opts=Instance.new("TeleportOptions")
        opts.ServerInstanceId=jobId
        TeleportService:TeleportAsync(PLACE_ID,{player},opts)
    end)
    return ok2
end

