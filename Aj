-- LOGIQUE
local function setStatus(txt,col)
    statusLbl.Text=txt; statusLbl.TextColor3=col or GR
end

local function stopAuto()
    autoOn=false
    if autoThread then task.cancel(autoThread); autoThread=nil end
    autoBtn.Text="⚡ AUTO JOIN: OFF"; autoBtn.TextColor3=WH
    TweenService:Create(autoBtn,TweenInfo.new(0.2),{BackgroundColor3=AC}):Play()
    TweenService:Create(ms,TweenInfo.new(0.2),{Color=AC}):Play()
    TweenService:Create(dot,TweenInfo.new(0.2),{BackgroundColor3=RD}):Play()
    setStatus("Auto arrêté",GR)
end

local function startAuto()
    autoOn=true
    autoBtn.Text="⚡ AUTO JOIN: ON"; autoBtn.TextColor3=GN
    TweenService:Create(autoBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(10,50,20)}):Play()
    TweenService:Create(ms,TweenInfo.new(0.2),{Color=GN}):Play()
    TweenService:Create(dot,TweenInfo.new(0.2),{BackgroundColor3=GN}):Play()
    setStatus("Scan en cours...",AC2)

    autoThread=task.spawn(function()
        while autoOn do
            local jobId=fetchJobId()
            if jobId and jobId~="" and jobId~=lastJobId then
                -- Nouveau jobId détecté !
                lastJobId=jobId
                jobVal.Text=jobId
                setStatus("✓ Nouveau job ! Joining...",GN)
                notif("✓ Nouveau serveur détecté ! Join...")
                TweenService:Create(ms,TweenInfo.new(0.2),{Color=GN}):Play()
                task.wait(0.5)
                joinJobId(jobId)
                -- Attend un peu avant de continuer à scanner
                task.wait(3)
            elseif jobId and jobId~="" then
                -- Même jobId, on attend
                jobVal.Text=jobId
                setStatus("En attente nouveau job...",GR)
            else
                setStatus("Bot: pas de jobId...",GR)
                jobVal.Text="—"
            end
            task.wait(pollInterval)
        end
    end)
end

autoBtn.MouseButton1Click:Connect(function()
