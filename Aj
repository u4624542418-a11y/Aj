local function doFetch()
    setStatus("Fetching...",AC2); setDot(AC2)
    local jobId,err=fetchJobId()
    if jobId then
        currentJobId=jobId; jobVal.Text=jobId
        setStatus("✓ JobId reçu !",GN); setDot(GN)
        TweenService:Create(ms,TweenInfo.new(0.2),{Color=GN}):Play()
        notif("✓ JobId: "..jobId:sub(1,18).."...")
        return true
    else
        currentJobId=nil; jobVal.Text="—"
        setStatus("❌ "..tostring(err),RD); setDot(RD)
        TweenService:Create(ms,TweenInfo.new(0.2),{Color=RD}):Play()
        return false
    end
end

local function stopAutoJoin()
    autoJoinOn=false
    if autoJoinThread then task.cancel(autoJoinThread); autoJoinThread=nil end
    autoBtn.Text="⚡ AUTO: OFF"; autoBtn.TextColor3=GR
    TweenService:Create(autoBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(30,10,60)}):Play()
    TweenService:Create(ms,TweenInfo.new(0.2),{Color=AC}):Play()
    setDot(RD)
end

local function startAutoJoin()
    autoJoinOn=true; autoRetries=0
    autoBtn.Text="⚡ AUTO: ON"; autoBtn.TextColor3=GN
    TweenService:Create(autoBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(10,50,20)}):Play()
    TweenService:Create(ms,TweenInfo.new(0.2),{Color=GN}):Play()
    setDot(GN)
    autoJoinThread=task.spawn(function()
        while autoJoinOn do
            local ok=doFetch()
            if ok and currentJobId then
                autoRetries=autoRetries+1
                setStatus("Auto "..autoRetries.."/"..maxRetries.." joining...",AC2)
                local joined=joinJobId(currentJobId)
                if joined then
                    setStatus("✓ Teleport lancé !",GN)
                    stopAutoJoin(); return
                end
                if autoRetries>=maxRetries then
                    setStatus("Max retries atteint",RD)
                    stopAutoJoin(); return
                end
            else
                setStatus("Pas de jobId ("..autoRetries..")",GR)
            end
            task.wait(pollInterval)
        end
    end)
end

